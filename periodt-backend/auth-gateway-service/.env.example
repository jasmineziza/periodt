# Salin file ini menjadi .env lalu sesuaikan nilainya.
# .env TIDAK boleh di-commit (sudah masuk .gitignore).

# Kunci rahasia untuk menandatangani JWT. WAJIB diganti dengan string acak kuat.
# Contoh generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=ganti-dengan-string-acak-yang-kuat

# Algoritma & masa berlaku token
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Koneksi database. Default SQLite lokal; untuk production pakai PostgreSQL, mis:
# DATABASE_URL=postgresql://user:password@localhost:5432/periodt_auth
DATABASE_URL=sqlite:///./auth.db

# Origin frontend yang diizinkan (pisahkan dengan koma)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# URL service hilir (dipakai gateway untuk forward request)
CYCLE_SERVICE_URL=http://cycle-wellness-service:8001
ANALYTICS_SERVICE_URL=http://analytics-reminder-service:8002
